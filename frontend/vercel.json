{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs@22",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/generate",
      "destination": "/api/generate"
    },
    {
      "source": "/api/v1/health",
      "destination": "/api/health"
    }
  ]
}
